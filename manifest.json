    }
  ],
  "shortcuts": [
    {
      "name": "Создать бота",
      "short_name": "Новый бот",
      "description": "Создать нового ИИ-ассистента",
      "url": "/index.html#create_bot",
      "icons": [
        {
          "src": "/assets/icons/shortcut-create-bot.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Мои боты",
      "short_name": "Боты",
      "description": "Управление созданными ботами",
      "url": "/index.html#bot_list",
      "icons": [
        {
          "src": "/assets/icons/shortcut-bots.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Плагины",
      "short_name": "Плагины",
      "description": "Установка и управление плагинами",
      "url": "/index.html#mods",
      "icons": [
        {
          "src": "/assets/icons/shortcut-plugins.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Настройки",
      "short_name": "Настройки",
      "description": "Конфигурация приложения",
      "url": "/index.html#settings",
      "icons": [
        {
          "src": "/assets/icons/shortcut-settings.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/index.html#share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "attachments",
          "accept": ["image/*", "application/json", ".txt"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+neobot",
      "url": "/index.html?share=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/index.html#import",
      "accept": {
        "application/json": [".json"],
        "text/plain": [".txt"]
      },
      "icons": [
        {
          "src": "/assets/icons/file-handler.png",
          "sizes": "128x128",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "prefer_related_applications": false,
  "related_applications": [],
  "iarc_rating_id": "",
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "enabled": true,
    "new_note_url": "/index.html#create_bot"
  },
  "serviceworker": {
    "src": "/sw.js",
    "scope": "/",
    "type": "module",
    "update_via_cache": "none"
  },
  "permissions": [
    "storage",
    "clipboard-read",
    "clipboard-write",
    "microphone",
    "speech-synthesis",
    "speech-recognition"
  ],
  "optional_permissions": [
    "notifications",
    "persistent-storage"
  ],
  "features": [
    "CrossPlatform",
    "OfflineSupport",
    "LocalAI",
    "PluginSystem",
    "VoiceInput",
    "TextToSpeech",
    "ImageGallery",
    "DataExport",
    "PrivacyFirst"
  ],
  "developer": {
    "name": "Zonar100",
    "url": "https://github.com/Zonar100ss"
  },
  "documentation": "https://github.com/Zonar100ss/neo-bot-studio/wiki",
  "support": {
    "email": "zonassffrr@gmail.com",
    "url": "https://github.com/Zonar100ss/neo-bot-studio/issues"
  },
  "privacy_policy": "https://github.com/Zonar100ss/neo-bot-studio/wiki/Privacy",
  "terms_of_service": "https://github.com/Zonar100ss/neo-bot-studio/wiki/Terms",
  "changelog": "https://github.com/Zonar100ss/neo-bot-studio/releases",
  "source_code": "https://github.com/Zonar100ss/neo-bot-studio",
  "feedback": {
    "url": "https://github.com/Zonar100ss/neo-bot-studio/issues",
    "email": "feedback@neobot-studio.dev"
  },
  "social": {
    "telegram": "https://t.me/+33HX40hFUCA2NTEy",
    "github": "https://github.com/Zonar100ss/neo-bot-studio"
  },
  "build_info": {
    "version": "1.0.0",
    "build_date": "2026-02-18",
    "build_number": 1000000,
    "channel": "stable"
  },
  "requirements": {
    "min_browser_version": {
      "chrome": 89,
      "firefox": 87,
      "safari": 14.1,
      "edge": 89
    },
    "features": [
      "localStorage",
      "ServiceWorker",
      "WebAssembly",
      "SpeechSynthesis",
      "SpeechRecognition",
      "ClipboardAPI",
      "FileAPI",
      "NotificationAPI"
    ]
  },
  "caching": {
    "strategy": "cache-first",
    "max_age": 604800,
    "precache": [
      "/",
      "/index.html",
      "/scripts/core/app.js",
      "/styles/neo-core.css",
      "/styles/neo-components.css",
      "/styles/neo-animations.css",
      "/styles/themes/dark-neon.css",
      "/styles/themes/light-glass.css",
      "/assets/icons/icon-192x192.png",
      "/assets/icons/icon-512x512.png"
    ],
    "runtime_caching": [
      {
        "url_pattern": "^https://fonts\\.googleapis\\.com/.*",
        "strategy": "cache-first",
        "max_age": 2592000
      },
      {
        "url_pattern": "^https://cdnjs\\.cloudflare\\.com/.*",
        "strategy": "cache-first",
        "max_age": 2592000
      }
    ]
  },
  "offline_enabled": true,
  "offline_page": "/offline.html",
  "error_page": "/error.html",
  "loading_page": "/loading.html"
}
