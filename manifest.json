{
  "name": "Neo-Bot Studio — Создание ИИ-ботов",
  "short_name": "Neo.Studio",
  "description": "Создавайте и управляйте ИИ-ботами с локальной моделью Qwen. Полная приватность, работа офлайн, плагины и кастомизация.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "portrait-primary",
  "background_color": "#0f0f13",
  "theme_color": "#0f0f13",
  "categories": ["productivity", "utilities", "developer tools"],
  "lang": "ru",
  "dir": "ltr",
  "icons": [
    { "src": "./assets/icons/icon-72x72.png", "sizes": "72x72", "type": "image/png", "purpose": "any" },
    { "src": "./assets/icons/icon-96x96.png", "sizes": "96x96", "type": "image/png", "purpose": "any" },
    { "src": "./assets/icons/icon-144x144.png", "sizes": "128x128", "type": "image/png", "purpose": "any" },
    { "src": "./assets/icons/icon-144x144.png", "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "./assets/icons/icon-152x152.png", "sizes": "152x152", "type": "image/jpeg", "purpose": "any" },
    { "src": "./assets/icons/icon-192x192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "./assets/icons/icon1.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "./assets/icons/icon-384x384.png", "sizes": "384x384", "type": "image/png", "purpose": "any" },
    { "src": "./assets/icons/icon-512x512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "./assets/icons/icon2.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" },
    { "src": "./assets/icons/icon-1024x1024.png", "sizes": "1024x1024", "type": "image/png", "purpose": "any" }
  ],
  "shortcuts": [
    {
      "name": "Создать бота",
      "short_name": "Новый бот",
      "description": "Создать нового ИИ-ассистента",
      "url": "./index.html#create_bot",
      "icons": [{ "src": "./assets/icons/icon1.png", "sizes": "96x96", "type": "image/png", "purpose": "any" }]
    },
    {
      "name": "Мои боты",
      "short_name": "Боты",
      "description": "Управление созданными ботами",
      "url": "./index.html#bot_list",
      "icons": [{ "src": "./assets/icons/icon1.png", "sizes": "96x96", "type": "image/png", "purpose": "any" }]
    },
    {
      "name": "Плагины",
      "short_name": "Плагины",
      "description": "Установка и управление плагинами",
      "url": "./index.html#mods",
      "icons": [{ "src": "./assets/icons/icon1.png", "sizes": "96x96", "type": "image/png", "purpose": "any" }]
    },
    {
      "name": "Настройки",
      "short_name": "Настройки",
      "description": "Конфигурация приложения",
      "url": "./index.html#settings",
      "icons": [{ "src": "./assets/icons/icon1.png", "sizes": "96x96", "type": "image/png", "purpose": "any" }]
    }
  ],
  "share_target": {
    "action": "./index.html#share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [{ "name": "attachments", "accept": ["image/*", "application/json", ".txt"] }]
    }
  },
  "protocol_handlers": [{ "protocol": "web+neobot", "url": "./index.html?share=%s" }],
  "file_handlers": [{
    "action": "./index.html#import",
    "accept": { "application/json": [".json"], "text/plain": [".txt"] },
    "icons": [{ "src": "./assets/icons/icon1.png", "sizes": "128x128", "type": "image/png", "purpose": "any" }],
    "launch_type": "single-client"
  }],
  "launch_handler": { "client_mode": "navigate-existing" },
  "handle_links": "preferred",
  "prefer_related_applications": false,
  "related_applications": [],
  "iarc_rating_id": "",
  "developer": {
    "name": "Zonar100",
    "url": "https://github.com/Zonar100ss"
  }
}
